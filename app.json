{
  "expo": {
    "name": "Anota",
    "slug": "anota",
    "version": "1.1.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/2498385a-d1cf-4513-a0c1-3cdc8f1d3410"
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#070D0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "dev.anota.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "dev.anota.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#070D0A"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-localization",
      "expo-font",
      "expo-iap"
    ],
    "extra": {
      "eas": {
        "projectId": "2498385a-d1cf-4513-a0c1-3cdc8f1d3410"
      }
    },
    "owner": "aaguasvivas"
  }
}
